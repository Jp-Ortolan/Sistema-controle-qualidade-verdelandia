# Banco local (recomendado — não exige instalar servidor)
# O ficheiro é criado em backend/prisma/dev.db após migrate + seed
DATABASE_URL="file:./dev.db"

# Opcional em produção: PostgreSQL (Supabase, Railway, etc.)
# Altere também prisma/schema.prisma → provider = "postgresql" e regenere migrações.
# DATABASE_URL="postgresql://USER:SENHA@HOST:5432/NOME_BD?schema=public"

# Em produção: mínimo 32 caracteres aleatórios (ex.: openssl rand -base64 48)
JWT_SECRET="trocar-este-segredo-em-producao-minimo-32-chars!!"
PORT=3333
CORS_ORIGIN="http://localhost:5173"
# Opcional: limite de tentativas de login por IP (predefinição 5 em produção, 20 em dev)
# LOGIN_RATE_LIMIT_MAX=5
# LOGIN_RATE_LIMIT_WINDOW_MS=900000
# Atrás de nginx/traefik com rate limit por IP real: TRUST_PROXY=1
# TRUST_PROXY=1
