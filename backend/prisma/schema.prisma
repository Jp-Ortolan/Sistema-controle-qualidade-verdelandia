generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  senhaHash String
  perfil    String
  createdAt DateTime @default(now())
}

model Produtor {
  id        Int             @id @default(autoincrement())
  nome      String          @unique
  cidade    String
  telefone  String
  createdAt DateTime        @default(now())
  analises  Analise[]
  coletas   ColetaAmostra[]
}

model Lote {
  id             Int              @id @default(autoincrement())
  codigo         String           @unique
  produto        String
  dataFabricacao DateTime
  observacao     String?
  createdAt      DateTime         @default(now())
  analises       Analise[]
  fichas         FichaEmbalagem[]
}

model Analise {
  id               Int       @id @default(autoincrement())
  produtorId       Int
  produtor         Produtor  @relation(fields: [produtorId], references: [id])
  loteId           Int?
  lote             Lote?     @relation(fields: [loteId], references: [id])
  ticket           String?
  dataAnalise      DateTime  @default(now())
  dataFabricacao   DateTime?
  percentualPalito Float
  teorPo           Float?
  umidade          Float?
  desconto         Float
  observacao       String?
  createdAt        DateTime  @default(now())
}

model FichaEmbalagem {
  id           Int      @id @default(autoincrement())
  loteId       Int?
  lote         Lote?    @relation(fields: [loteId], references: [id])
  fornecedor   String
  parametros   String
  observacoes  String?
  statusGlobal String
  createdAt    DateTime @default(now())
}

model ColetaAmostra {
  id          Int       @id @default(autoincrement())
  produtorId  Int?
  produtor    Produtor? @relation(fields: [produtorId], references: [id])
  tipoProduto String
  destino     String
  dataColeta  DateTime
  createdAt   DateTime  @default(now())
}
